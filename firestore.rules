rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // User profiles: only the owner can read/write
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Rooms (legacy): authenticated users can read any room, create new rooms
    match /rooms/{roomCode} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && request.auth.uid == resource.data.createdBy;
      allow delete: if request.auth != null && request.auth.uid == resource.data.createdBy;
    }

    // Servers: authenticated users can read, create
    match /servers/{serverCode} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow delete: if request.auth != null && request.auth.uid == resource.data.ownerId;

      // Channels within servers
      match /channels/{channelId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
          && exists(/databases/$(database)/documents/serverMembers/$(request.auth.uid + "|" + serverCode));
      }
    }

    // Server memberships
    match /serverMembers/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && (
          get(/databases/$(database)/documents/servers/$(request.resource.data.serverCode)).data.joinType == "open"
          || exists(/databases/$(database)/documents/servers/$(request.resource.data.serverCode)/serverInvites/$(request.resource.data.inviteCode))
        );
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // Server invites
    match /servers/{serverCode}/serverInvites/{inviteCode} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // Server roles: only the owner can create/update/delete
    match /servers/{serverCode}/roles/{roleId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null
        && get(/databases/$(database)/documents/servers/$(serverCode)).data.ownerId == request.auth.uid;
    }

    // Messages: authenticated users can read, create their own messages
    match /messages/{messageId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.senderId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.senderId == request.auth.uid;
    }

    // Errors (Para): users can only read their own errors
    match /errors/{errorId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }
  }
}
